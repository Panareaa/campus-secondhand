# 拾光校园 · Docker 全栈环境变量（复制为 .env 后按需修改）
# cp .env.example .env

# MySQL
MYSQL_ROOT_PASSWORD=relife_root
MYSQL_USER=relife
MYSQL_PASSWORD=relife123

# JWT / 内部调用（各服务须一致）
JWT_SECRET=CampusRelifeDevSecretKey2026ChangeInProd!
INTERNAL_TOKEN=CampusRelifeInternalDevToken2026

# AI（默认关闭 LLM，使用模板降级，便于演示与测试）
AI_LLM_ENABLED=false
# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4o-mini

# 交易超时（分钟）
TRADE_PENDING_TIMEOUT_MINUTES=1440

# Gateway 限流（报告演示可临时调低 GATEWAY_RATE_LIMIT）
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT=10
GATEWAY_RATE_LIMIT_WINDOW=10

# Nacos（Docker 全栈默认启用注册发现 + 配置中心）
NACOS_ADDR=nacos:8848
NACOS_DISCOVERY_ENABLED=true
NACOS_CONFIG_ENABLED=true
# 控制台映射：容器 8080 → 宿主机 8849（避免与 Gateway :8080 冲突）
